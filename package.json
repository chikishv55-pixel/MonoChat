{
  "name": "monochrome-chat",
  "version": "1.0.0",
  "description": "Minimalist real-time chat",
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "electron:start": "electron .",
    "electron:build": "electron-builder --win --dir",
    "electron:pack": "electron-builder --win"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "bcryptjs": "^3.0.3",
    "cordova-plugin-background-mode": "^0.7.3",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mime-types": "^2.1.35",
    "nodemailer": "^6.9.1",
    "socket.io": "^4.7.2",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.monochat.app",
    "productName": "MonoChat",
    "win": {
      "target": "nsis",
      "icon": "public/favicon.ico"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "public/**/*",
      "src/**/*",
      "server.js",
      "electron-main.js",
      "package.json"
    ],
    "extraResources": [
      "chat.db"
    ]
  },
  "keywords": [],
  "author": "Sivoiv",
  "license": "ISC",
  "type": "commonjs"
}
